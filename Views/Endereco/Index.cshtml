@model IEnumerable<TesteDevAEC.Models.Endereco>

<div class="py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1 class="h3 aec-page-title">Meus endereços</h1>
            <p class="aec-page-lead mb-0">Visualize, edite ou exporte os endereços vinculados à sua conta. Novos cadastros podem usar busca por CEP (ViaCEP).</p>
        </div>
        <div class="d-flex flex-wrap gap-2 ms-md-auto justify-content-md-end">
            <a asp-action="ExportarCsv" class="btn btn-aec-outline btn-sm d-inline-flex align-items-center gap-1">
                <i class="bi bi-download"></i> Exportar CSV
            </a>
            <a asp-action="Create" class="btn btn-aec-primary btn-sm d-inline-flex align-items-center gap-1">
                <i class="bi bi-plus-lg"></i> Novo endereço
            </a>
        </div>
    </div>

    <div class="aec-table-card">
        <div class="table-responsive">
            <table class="table aec-table align-middle">
                <thead>
                    <tr>
                        <th scope="col">CEP</th>
                        <th scope="col">Logradouro</th>
                        <th scope="col">Bairro</th>
                        <th scope="col">Cidade / UF</th>
                        <th scope="col">Número</th>
                        <th scope="col" class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="p-0">
                                <div class="aec-empty">
                                    <i class="bi bi-inbox" aria-hidden="true"></i>
                                    <p class="mb-2 fw-medium text-body-secondary">Nenhum endereço cadastrado ainda.</p>
                                    <a asp-action="Create" class="btn btn-aec-primary btn-sm">Cadastrar primeiro endereço</a>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="font-monospace">@item.Cep</span></td>
                                <td>@item.Logradouro</td>
                                <td>@item.Bairro</td>
                                <td>@item.Cidade <span class="text-secondary">/</span> @item.Uf</td>
                                <td>@item.Numero</td>
                                <td class="text-end">
                                    <div class="aec-table-actions justify-content-end">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil me-1"></i>Editar
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Excluir este endereço? Esta ação não pode ser desfeita.');" aria-label="Excluir endereço">
                                                <i class="bi bi-trash me-1"></i>Excluir
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
