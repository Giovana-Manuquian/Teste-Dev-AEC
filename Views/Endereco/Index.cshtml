@model IEnumerable<TesteDevAEC.Models.Endereco>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Meus Endereços</h2>
        <a asp-action="Create" class="btn btn-primary">Cadastrar Novo</a>
    </div>

    <table class="table table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>CEP</th>
                <th>Logradouro</th>
                <th>Bairro</th>
                <th>Cidade/UF</th>
                <th>Número</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Cep</td>
                    <td>@item.Logradouro</td>
                    <td>@item.Bairro</td>
                    <td>@item.Cidade/@item.Uf</td>
                    <td>@item.Numero</td>
                    <td>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Deseja excluir?')">Excluir</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>