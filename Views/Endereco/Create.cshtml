@model TesteDevAEC.Models.Endereco

<div class="py-4">
    <div class="mb-4">
        <h1 class="h3 aec-page-title">Cadastrar endereço</h1>
        <p class="aec-page-lead mb-0">Preencha o CEP para buscar dados no ViaCEP ou digite manualmente. Campos marcados com <span class="text-danger">*</span> são obrigatórios.</p>
    </div>

    <div class="aec-card p-4 p-md-5">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small" role="alert"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label" asp-for="Cep">CEP <span class="text-danger">*</span></label>
                    <input asp-for="Cep" id="txtCep" class="form-control font-monospace" placeholder="00000000" maxlength="9" required />
                    <p class="form-hint mb-0">Ao informar 8 dígitos, os dados serão preenchidos automaticamente.</p>
                    <span asp-validation-for="Cep" class="text-danger small d-block"></span>
                </div>
                <div class="col-md-8">
                    <label class="form-label" asp-for="Logradouro">Logradouro <span class="text-danger">*</span></label>
                    <input asp-for="Logradouro" id="txtLogradouro" class="form-control" required />
                    <span asp-validation-for="Logradouro" class="text-danger small d-block"></span>
                </div>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-md-5">
                    <label class="form-label" asp-for="Bairro">Bairro <span class="text-danger">*</span></label>
                    <input asp-for="Bairro" id="txtBairro" class="form-control" required />
                    <span asp-validation-for="Bairro" class="text-danger small d-block"></span>
                </div>
                <div class="col-md-5">
                    <label class="form-label" asp-for="Cidade">Cidade <span class="text-danger">*</span></label>
                    <input asp-for="Cidade" id="txtCidade" class="form-control" required />
                    <span asp-validation-for="Cidade" class="text-danger small d-block"></span>
                </div>
                <div class="col-md-2">
                    <label class="form-label" asp-for="Uf">UF <span class="text-danger">*</span></label>
                    <input asp-for="Uf" id="txtUf" class="form-control text-uppercase" maxlength="2" required />
                    <span asp-validation-for="Uf" class="text-danger small d-block"></span>
                </div>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-md-4">
                    <label class="form-label" asp-for="Numero">Número <span class="text-danger">*</span></label>
                    <input asp-for="Numero" class="form-control" maxlength="10" required />
                    <span asp-validation-for="Numero" class="text-danger small d-block"></span>
                </div>
                <div class="col-md-8">
                    <label class="form-label" asp-for="Complemento">Complemento <span class="text-secondary fw-normal">(opcional)</span></label>
                    <input asp-for="Complemento" class="form-control" placeholder="Apto, bloco, referência…" />
                    <span asp-validation-for="Complemento" class="text-danger small d-block"></span>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top">
                <button type="submit" class="btn btn-success btn-aec-success">
                    <i class="bi bi-check2-circle me-1"></i>Salvar endereço
                </button>
                <a asp-action="Index" class="btn btn-aec-outline">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.getElementById('txtCep').addEventListener('input', function() {
            var cep = this.value.replace(/\D/g, '');

            if (cep.length === 8) {
                document.getElementById('txtLogradouro').value = "Buscando...";
                document.getElementById('txtBairro').value = "Buscando...";
                document.getElementById('txtCidade').value = "Buscando...";
                document.getElementById('txtUf').value = "..";

                fetch(`https://viacep.com.br/ws/${cep}/json/`)
                    .then(response => response.json())
                    .then(data => {
                        if (!data.erro) {
                            document.getElementById('txtLogradouro').value = data.logradouro;
                            document.getElementById('txtBairro').value = data.bairro;
                            document.getElementById('txtCidade').value = data.localidade;
                            document.getElementById('txtUf').value = data.uf;
                        } else {
                            alert("CEP não encontrado.");
                            limparCampos();
                        }
                    })
                    .catch(error => {
                        console.error('Erro:', error);
                        limparCampos();
                    });
            }
        });

        function limparCampos() {
            document.getElementById('txtLogradouro').value = "";
            document.getElementById('txtBairro').value = "";
            document.getElementById('txtCidade').value = "";
            document.getElementById('txtUf').value = "";
        }
    </script>
}
