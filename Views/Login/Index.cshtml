@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4 card p-4 shadow">
            <h2 class="text-center">Acessar Sistema</h2>
            <hr />
            
            @if (ViewBag.Erro != null)
            {
                <div class="alert alert-danger">@ViewBag.Erro</div>
            }

            <form asp-action="Autenticar" asp-controller="Login" method="post">
                <div class="form-group mb-3">
                    <label>Usuário</label>
                    <input type="text" name="login" class="form-control" placeholder="Digite seu usuário" required />
                </div>
                <div class="form-group mb-3">
                    <label>Senha</label>
                    <input type="password" name="senha" class="form-control" placeholder="Digite sua senha" required />
                </div>
                <button type="submit" class="btn btn-primary w-100">Entrar</button>
            </form>
        </div>
    </div>
</div>