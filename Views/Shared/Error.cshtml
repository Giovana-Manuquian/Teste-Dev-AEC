@model ErrorViewModel
@{
    ViewData["Title"] = "Erro";
}

<div class="py-5 text-center">
    <div class="aec-card p-5 d-inline-block text-start" style="max-width: 32rem;">
        <h1 class="h4 text-danger mb-2"><i class="bi bi-exclamation-octagon me-2"></i>Algo deu errado</h1>
        <p class="text-secondary mb-3">Não foi possível concluir a solicitação. Se estiver em desenvolvimento, verifique os detalhes no console ou na página de exceção.</p>
        @if (Model.ShowRequestId)
        {
            <p class="small font-monospace text-secondary mb-0">
                <strong>Request ID:</strong> @Model.RequestId
            </p>
        }
        <hr class="my-4" />
        <a class="btn btn-aec-primary" asp-controller="Home" asp-action="Index">Voltar ao início</a>
    </div>
</div>
